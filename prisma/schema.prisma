generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetKind {
  IMAGE
  VIDEO
}

enum TagType {
  SERVICE
  CONTEXT
}

enum ProjectStatus {
  DRAFT
  READY
  PUBLISHED
}

model ServiceType {
  id        String     @id @default(cuid())
  slug      String
  title     String
  tagType   TagType    @default(SERVICE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  AssetTags AssetTag[]

  @@unique([slug, tagType])
}

model Asset {
  id                 String         @id @default(cuid())
  kind               AssetKind
  publicId           String         @unique
  secureUrl          String
  width              Int?
  height             Int?
  duration           Float?
  format             String?
  bytes              Int?
  title              String?
  description        String?
  location           String?
  primaryServiceSlug String?
  serviceMetadata    Json?
  alt                String?
  uploadBatchId      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  published          Boolean        @default(false)
  tags               AssetTag[]
  projectLinks       ProjectAsset[]
  coverForProjects   Project[]      @relation("ProjectCoverAsset")
}

model AssetTag {
  assetId       String
  serviceTypeId String
  asset         Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@id([assetId, serviceTypeId])
}

model Project {
  id                 String         @id @default(cuid())
  title              String
  slug               String         @unique
  description        String?
  serviceSlug        String?
  areaSlug           String?
  location           String?
  status             ProjectStatus  @default(DRAFT)
  published          Boolean        @default(false)
  featured           Boolean        @default(false)
  homepageSpotlight  Boolean        @default(false)
  heroEligible       Boolean        @default(false)
  spotlightRank      Int?
  primaryCtaLabel    String?
  primaryCtaHref     String?
  testimonialPresent Boolean        @default(false)
  completionYear     Int?
  internalNotes      String?
  featuredReason     String?
  coverAssetId       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  assets             ProjectAsset[]
  coverAsset         Asset?         @relation("ProjectCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
}

model ProjectAsset {
  projectId String
  assetId   String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([projectId, assetId])
  @@unique([projectId, position])
  @@index([assetId])
}

model Lead {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  name            String
  email           String
  phone           String
  service         String
  location        String
  timeline        String?
  budget          String?
  message         String
  photoUrls       String[]
  status          LeadStatus @default(NEW)
  sourceType      String?
  sourcePath      String?
  projectTitle    String?
  projectSlug     String?
  areaSlug        String?
  internalNotes   String?
  lastContactedAt DateTime?
  contactedVia    String?
  followUpAt      DateTime?
  archivedAt      DateTime?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referrer        String?
}

enum LeadStatus {
  NEW
  REVIEWED
  CONTACTED
  ARCHIVED
}
