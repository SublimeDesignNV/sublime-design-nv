generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AssetKind {
  IMAGE
  VIDEO
}

enum TagType {
  SERVICE
  CONTEXT
}

enum ProjectStatus {
  DRAFT
  READY
  PUBLISHED
}

model ServiceType {
  id         String     @id @default(cuid())
  slug       String
  title      String
  tagType    TagType    @default(SERVICE)
  coverImage String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  AssetTags  AssetTag[]

  @@unique([slug, tagType])
}

model Asset {
  id                 String         @id @default(cuid())
  kind               AssetKind
  publicId           String         @unique
  secureUrl          String
  width              Int?
  height             Int?
  duration           Float?
  format             String?
  bytes              Int?
  title              String?
  description        String?
  location           String?
  primaryServiceSlug String?
  serviceMetadata    Json?
  alt                String?
  uploadBatchId      String?
  materials          String[]       @default([])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  published          Boolean        @default(false)
  galleryFeature     Boolean        @default(false)
  tags               AssetTag[]
  projectLinks       ProjectAsset[]
  coverForProjects   Project[]      @relation("ProjectCoverAsset")
  paintColors        AssetPaintColor[]
}

model PaintColor {
  id     String  @id @default(cuid())
  brand  String  @default("Sherwin-Williams")
  code   String  @unique
  number String?
  name   String
  hex    String
  r      Int
  g      Int
  b      Int
  assets AssetPaintColor[]

  @@index([name])
  @@index([code])
}

model AssetPaintColor {
  id           String     @id @default(cuid())
  assetId      String
  asset        Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  paintColorId String
  paintColor   PaintColor @relation(fields: [paintColorId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([assetId, paintColorId])
}

model AssetTag {
  assetId       String
  serviceTypeId String
  asset         Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  serviceType   ServiceType @relation(fields: [serviceTypeId], references: [id], onDelete: Cascade)

  @@id([assetId, serviceTypeId])
}

model Project {
  id                 String         @id @default(cuid())
  title              String
  slug               String         @unique
  description        String?
  serviceSlug        String?
  areaSlug           String?
  location           String?
  status             ProjectStatus  @default(DRAFT)
  published          Boolean        @default(false)
  featured           Boolean        @default(false)
  homepageSpotlight  Boolean        @default(false)
  heroEligible       Boolean        @default(false)
  spotlightRank      Int?
  primaryCtaLabel    String?
  primaryCtaHref     String?
  testimonialPresent Boolean        @default(false)
  completionYear     Int?
  completionMonth    Int?
  internalNotes      String?
  featuredReason     String?
  coverAssetId       String?
  finishes           Json?          @default("[]")
  instagramCaption   String?
  facebookCaption    String?
  hashtagSet         String?
  socialExportedAt   DateTime?
  externalId         String?
  externalSource     String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  assets             ProjectAsset[]
  coverAsset         Asset?         @relation("ProjectCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  scheduledPosts     ScheduledPost[]
}


model ScheduledPost {
  id             String    @id @default(cuid())
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform       String
  caption        String
  hashtags       String?
  mediaAssetIds  String[]
  scheduledFor   DateTime?
  status         String    @default("pending")
  postedAt       DateTime?
  postId         String?
  errorMessage   String?
  // Pinterest-specific
  pinTitle          String?
  pinUrl            String?
  boardId           String?
  pinterestBoardId  String?
  altText           String?
  // YouTube-specific
  title          String?
  description    String?
  visibility     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model BusinessSettings {
  id                String   @id @default(cuid())
  companyName       String   @default("Sublime Design NV")
  tagline           String?  @default("Custom Woodwork. Elevated.")
  phone             String   @default("702-847-9016")
  email             String   @default("info@sublimedesignnv.com")
  address           String?
  city              String?  @default("Las Vegas")
  state             String?  @default("NV")
  zip               String?
  website           String?  @default("https://sublimedesignnv.com")
  instagramHandle   String?
  facebookUrl       String?
  pinterestUrl      String?
  youtubeUrl        String?
  googlePlaceId     String?
  gbpLocationId     String?
  hoursMonFri       String?  @default("7:00 AM – 6:00 PM")
  hoursSat          String?
  hoursSun          String?
  serviceRadius     Int?     @default(50)
  primaryTrade      String?  @default("Finish Carpentry")
  secondaryTrade    String?
  brandPrimary      String   @default("#CC2027")
  brandSecondary    String   @default("#1B2A6B")
  heroHeadline      String?
  heroSubheadline   String?
  heroCtaLabel      String?  @default("Start with a Quote")
  cloudinaryFolder      String   @default("Sublime/Portfolio/")
  cloudinaryQuality     String   @default("auto")
  cloudinaryMaxSizeMB   Int      @default(15)
  emailFromName         String   @default("Sublime Design NV")
  emailFromAddress      String   @default("info@sublimedesignnv.com")
  emailReplyTo          String   @default("info@sublimedesignnv.com")
  emailNotifyAddresses  String[] @default(["info@sublimedesignnv.com"])
  notifyNewLead         Boolean  @default(true)
  notifyStaleLead       Boolean  @default(true)
  notifyIntakeComplete  Boolean  @default(true)
  notifyKioskSubmit     Boolean  @default(true)
  notifyDailyDigest     Boolean  @default(false)
  notifyWeeklyDigest    Boolean  @default(false)
  notifySmsIntakeLink   Boolean  @default(true)
  notifySmsKiosk        Boolean  @default(true)
  showAddress         Boolean  @default(true)
  showPhone           Boolean  @default(true)
  showEmail           Boolean  @default(true)
  showHours           Boolean  @default(true)
  showLicenseNumbers  Boolean  @default(true)
  showServiceArea     Boolean  @default(true)
  showSocialLinks     Boolean  @default(true)
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}

model HeroSlide {
  id        String   @id @default(cuid())
  url       String
  publicId  String
  mediaType String
  alt       String?
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteMedia {
  id        String   @id @default(cuid())
  key       String   @unique
  url       String
  publicId  String
  mediaType String
  alt       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContractorLicense {
  id            String    @id @default(cuid())
  licenseType   String
  licenseNumber String
  issuingState  String?   @default("NV")
  expiresAt     DateTime?
  showOnSite    Boolean   @default(true)
  position      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PinterestBoard {
  id          String   @id @default(cuid())
  boardId     String   @unique
  name        String
  description String?
  url         String?
  imageUrl    String?
  pinCount    Int      @default(0)
  serviceType String?
  area        String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SocialAccount {
  id           String    @id @default(cuid())
  platform     String    @unique
  accountId    String?
  accountName  String?
  accessToken  String?
  refreshToken String?
  tokenExpiry  DateTime?
  connected    Boolean   @default(false)
  connectedAt  DateTime?
  updatedAt    DateTime  @updatedAt
}

model ProjectAsset {
  projectId String
  assetId   String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([projectId, assetId])
  @@unique([projectId, position])
  @@index([assetId])
}

model Lead {
  id              String     @id @default(cuid())
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  name            String
  email           String
  phone           String
  service         String
  location        String
  timeline        String?
  budget          String?
  message         String
  photoUrls       String[]
  status          LeadStatus @default(NEW)
  classification  LeadClassification @default(QUOTE_REQUEST)
  sourceType      String?
  sourcePath      String?
  projectTitle    String?
  projectSlug     String?
  areaSlug        String?
  internalNotes   String?
  lastContactedAt DateTime?
  contactedVia    String?
  followUpAt      DateTime?
  archivedAt      DateTime?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referrer        String?
}

enum LeadStatus {
  NEW
  REVIEWED
  CONTACTED
  ARCHIVED
}

enum LeadClassification {
  QUOTE_REQUEST
  PROJECT_LEAD
  SERVICE_INQUIRY
  GENERAL_QUESTION
  FOLLOW_UP
  SPAM
  OTHER
}

// ─── Intake Lead Flow ────────────────────────────────────────────────────────

enum IntakeServiceType {
  BARN_DOORS
  CABINETS
  CUSTOM_CLOSETS
  FAUX_BEAMS
  FLOATING_SHELVES
  MANTELS
  TRIM_WORK
  MULTIPLE
  OTHER
}

enum IntakeAssetType {
  SPACE_PHOTO
  INSPIRATION_PHOTO
  VIDEO
  PRODUCT_LINK
  INSPIRATION_LINK
  VISION_RENDER
}

enum IntakeLeadStatus {
  NEW
  INTAKE_SENT
  INTAKE_STARTED
  INTAKE_COMPLETE
  VISION_GENERATED
  BID_READY
  CONVERTED
  CLOSED
}

enum VisionStatus {
  PENDING
  GENERATING
  COMPLETE
  FAILED
}

model IntakeLead {
  id           String           @id @default(cuid())
  token        String           @unique @default(cuid())
  firstName    String
  lastName     String?
  phone        String?
  email        String?
  serviceType  IntakeServiceType
  projectNotes String?
  intakeData   Json?
  assets       IntakeLeadAsset[]
  visionPrompt String?
  visionResult Json?
  visionStatus VisionStatus     @default(PENDING)
  source       String           @default("web")
  status       IntakeLeadStatus @default(NEW)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model IntakeLeadAsset {
  id           String          @id @default(cuid())
  leadId       String
  lead         IntakeLead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type         IntakeAssetType
  url          String
  cloudinaryId String?
  caption      String?
  createdAt    DateTime        @default(now())
}

// ─── Materials System ────────────────────────────────────────────────────────

model MaterialCategory {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  description String?
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Manufacturer {
  id          String     @id @default(cuid())
  name        String     @unique
  slug        String     @unique
  website     String?
  description String?
  logoUrl     String?
  materials   Material[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Supplier {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  website     String?
  phone       String?
  address     String?
  city        String?
  state       String?
  description String?
  logoUrl     String?
  pricing     SupplierPricing[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Material {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  sku            String?
  description    String?
  imageUrl       String?
  isPublic       Boolean           @default(true)
  categoryId     String
  category       MaterialCategory  @relation(fields: [categoryId], references: [id])
  manufacturerId String
  manufacturer   Manufacturer      @relation(fields: [manufacturerId], references: [id])
  services       MaterialService[]
  pricing        SupplierPricing[]
  grade          String?
  sheen          String?
  finish         String?
  thickness      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model SupplierPricing {
  id          String    @id @default(cuid())
  materialId  String
  material    Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sheetPrice  Float?
  cutPrice    Float?
  cutUnit     String?
  unit        String?   @default("sheet")
  notes       String?
  lastUpdated DateTime  @default(now())
  isPreferred Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([materialId, supplierId])
}

model MaterialService {
  id         String   @id @default(cuid())
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  serviceId  String

  @@unique([materialId, serviceId])
}
